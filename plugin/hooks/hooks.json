{
    "description": "Symbiote lifecycle hooks — injects code intelligence context into every Claude Code interaction",
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.sh",
                        "timeout": 30
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh user-prompt-submit",
                        "timeout": 15
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh pre-tool-use",
                        "timeout": 15
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh post-tool-use",
                        "timeout": 15
                    }
                ]
            }
        ],
        "PostToolUseFailure": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh post-tool-use-failure",
                        "timeout": 15
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh subagent-start",
                        "timeout": 15
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "manual|auto",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh pre-compact",
                        "timeout": 15
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh stop",
                        "timeout": 15
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/symbiote-hook.sh session-end",
                        "timeout": 15
                    }
                ]
            }
        ]
    }
}
