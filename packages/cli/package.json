{
    "name": "symbiote-cli",
    "version": "0.1.0",
    "description": "AI-powered project brain — a living, queryable knowledge layer for your codebase",
    "type": "module",
    "bin": {
        "symbiote": "./dist/bin/symbiote.js"
    },
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js"
        }
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@clack/prompts": "^0.10.0",
        "@huggingface/transformers": "^3.8.1",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "chokidar": "^4.0.0",
        "@duckdb/node-api": "1.5.0-r.1",
        "glob": "^11.0.0",
        "picocolors": "^1.1.0",
        "tree-sitter": "^0.22.0",
        "tree-sitter-c": "^0.23.0",
        "tree-sitter-cpp": "^0.23.0",
        "tree-sitter-go": "^0.23.0",
        "tree-sitter-java": "^0.23.0",
        "tree-sitter-javascript": "^0.23.0",
        "tree-sitter-php": "^0.23.0",
        "tree-sitter-python": "^0.23.0",
        "tree-sitter-ruby": "^0.23.0",
        "tree-sitter-rust": "^0.23.0",
        "tree-sitter-typescript": "^0.23.0",
        "graphology": "^0.25.4",
        "graphology-communities-louvain": "^2.0.1",
        "graphology-metrics": "^2.3.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "keywords": [
        "ai",
        "mcp",
        "mcp-server",
        "ai-coding",
        "claude",
        "cursor",
        "copilot",
        "windsurf",
        "code-context",
        "code-intelligence",
        "tree-sitter",
        "knowledge-graph",
        "developer-tools"
    ],
    "author": {
        "name": "Mohamed Ashraf",
        "email": "cupo.ashraf@gmail.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/MohmmedAshraf/symbiote.git"
    },
    "homepage": "https://github.com/MohmmedAshraf/symbiote"
}
