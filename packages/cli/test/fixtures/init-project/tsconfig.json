{
    "compilerOptions": {
        "target": "ES2022", "module": "Node16", "moduleResolution": "Node16",
        "strict": true, "noUncheckedIndexedAccess": true, "exactOptionalPropertyTypes": true,
        "noImplicitReturns": true, "paths": { "@/*": ["./src/*"] }
    },
    "include": ["src/**/*"], "exclude": ["node_modules"]
}
